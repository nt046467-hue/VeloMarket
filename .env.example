# PostgreSQL connection string (required)
# Local: postgresql://user:password@localhost:5432/zshop
# Neon:  postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/zshop?sslmode=require
DATABASE_URL=

# Session signing secret — use any strong random string in production
# Example: openssl rand -base64 32
SESSION_SECRET=

# Groq API key — get a free key at https://console.groq.com
GROQ_API_KEY=
